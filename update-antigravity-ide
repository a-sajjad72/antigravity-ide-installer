#!/usr/bin/env bash
set -euo pipefail

###############################################################################
# Antigravity IDE Installer / Updater
#
# Features:
# - Fresh install
# - Safe upgrades
# - Profile backup before upgrade
# - Legacy profile migration
# - Rollback support
# - Version check mode
###############################################################################

if [ "$(id -u)" -ne 0 ]; then
    echo "Run with sudo: sudo update-antigravity-ide [--check|--rollback]" >&2
    exit 1
fi

ACTION="${1:-install}"

download_page="https://antigravity.google/download"

install_root="/opt/antigravity-ide"
install_dir="Antigravity-IDE"

command_link="/usr/local/bin/antigravity-ide"
desktop_file="/usr/share/applications/antigravity-ide.desktop"
icon_file="/usr/share/icons/hicolor/512x512/apps/antigravity-ide.png"

archive_top_dir="Antigravity IDE"

###############################################################################
# Determine invoking user's home directory
###############################################################################

if [ -n "${SUDO_USER:-}" ]; then
    SUDO_USER_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)
else
    SUDO_USER_HOME="$HOME"
fi

legacy_profile="$SUDO_USER_HOME/.config/Antigravity"
new_profile="$SUDO_USER_HOME/.config/Antigravity IDE"

backup_root="$SUDO_USER_HOME/.cache/antigravity-ide-backups"

###############################################################################
# Rollback
###############################################################################

if [ "$ACTION" = "--rollback" ]; then
    if [ ! -d "${install_root}.previous" ]; then
        echo "No rollback installation found."
        exit 1
    fi

    echo "Rolling back to previous installation..."

    rm -rf "${install_root}.rollback-temp"
    mv "$install_root" "${install_root}.rollback-temp"
    mv "${install_root}.previous" "$install_root"
    mv "${install_root}.rollback-temp" "${install_root}.previous"

    echo "Rollback completed."
    exit 0
fi

###############################################################################
# Architecture detection
###############################################################################

case "$(uname -m)" in
    x86_64|amd64) platform="linux-x64" ;;
    aarch64|arm64) platform="linux-arm" ;;
    *)
        echo "Unsupported architecture: $(uname -m)" >&2
        exit 1
        ;;
esac

###############################################################################
# Dependency checks
###############################################################################

for required_command in curl tar python3; do
    if ! command -v "$required_command" >/dev/null 2>&1; then
        echo "$required_command is required." >&2
        exit 1
    fi
done

###############################################################################
# Download metadata
###############################################################################

tmp_parent="${TMPDIR:-/var/tmp}"
mkdir -p "$tmp_parent"

tmpdir=$(mktemp -d "$tmp_parent/antigravity-ide.XXXXXX")
trap 'rm -rf "$tmpdir"' EXIT

download_html="$tmpdir/download.html"
download_js="$tmpdir/download.js"
archive="$tmpdir/Antigravity-IDE.tar.gz"
archive_list="$tmpdir/archive-list.txt"

curl -fsSL --compressed --retry 3 \
    -o "$download_html" "$download_page"

main_js_url=$(
python3 - "$download_html" "$download_page" <<'PY'
import re
import sys
from pathlib import Path
from urllib.parse import urljoin

html = Path(sys.argv[1]).read_text()
page_url = sys.argv[2]

matches = re.findall(r'(?:src|href)="([^"]*main-[^"]+\.js)"', html)

if not matches:
    raise SystemExit("Could not find download bundle")

print(urljoin(page_url, matches[-1]))
PY
)

curl -fsSL --compressed --retry 3 \
    -o "$download_js" "$main_js_url"

download_fields=$(
python3 - "$download_js" "$platform" <<'PY'
import re
import sys
from pathlib import Path

bundle = Path(sys.argv[1]).read_text(errors="replace")
platform = sys.argv[2]

start = bundle.find('id:"antigravity-ide"')
end = bundle.find('},{name:"download",id:"antigravity-sdk"', start)

if start == -1 or end == -1:
    raise SystemExit("Could not find IDE downloads")

section = bundle[start:end]

match = re.search(
    r'href:"([^"]+/' + re.escape(platform) +
    r'/Antigravity%20IDE\.tar\.gz)"',
    section
)

if not match:
    raise SystemExit("No download found")

url = match.group(1)

version_match = re.search(r'/stable/([^/]+)/', url)

if not version_match:
    raise SystemExit("Could not parse version")

print(version_match.group(1).split("-", 1)[0], url)
PY
)

read -r version download_url <<<"$download_fields"

installed_version=$(cat "$install_root/.linuxcapable-version" 2>/dev/null || true)

###############################################################################
# Check mode
###############################################################################

if [ "$ACTION" = "--check" ]; then
    echo "Installed : ${installed_version:-none}"
    echo "Latest    : $version"

    if [ "$installed_version" = "$version" ]; then
        echo "Status    : Up to date"
    else
        echo "Status    : Update available"
    fi

    exit 0
fi

###############################################################################
# Skip if already installed
###############################################################################

expected_target="$install_root/$install_dir/antigravity-ide"

if [ "$installed_version" = "$version" ] &&
   [ -x "$expected_target" ]; then
    echo "Antigravity IDE $version already installed."
    exit 0
fi

###############################################################################
# Profile backup
###############################################################################

mkdir -p "$backup_root"

if [ -d "$new_profile" ]; then
    backup_file="$backup_root/profile-$(date +%F-%H%M%S).tar.gz"

    echo "Backing up profile to:"
    echo "  $backup_file"

    tar -czf "$backup_file" \
        -C "$SUDO_USER_HOME/.config" \
        "Antigravity IDE"
fi

###############################################################################
# Legacy migration
###############################################################################

if [ -d "$legacy_profile" ] &&
   [ ! -d "$new_profile" ]; then

    echo
    echo "Legacy Antigravity profile detected:"
    echo "  $legacy_profile"
    echo

    read -rp "Migrate profile to Antigravity IDE? [Y/n] " answer

    if [[ ! "$answer" =~ ^[Nn]$ ]]; then

        cp -a "$legacy_profile" "$new_profile"

        rm -f \
            "$new_profile"/code.lock \
            "$new_profile"/SingletonCookie \
            "$new_profile"/SingletonLock \
            "$new_profile"/SingletonSocket \
            "$new_profile"/DevToolsActivePort

        chown -R "$SUDO_USER":"$SUDO_USER" "$new_profile"

        echo "Profile migration completed."
    fi
fi

###############################################################################
# Download and install
###############################################################################

echo "Downloading Antigravity IDE $version..."

curl -fsSL --retry 3 \
    -o "$archive" "$download_url"

tar -tzf "$archive" > "$archive_list"

top_dir=$(sed -n '1{s#/.*##;p;q}' "$archive_list")

if [ "$top_dir" != "$archive_top_dir" ]; then
    echo "Unexpected archive structure."
    exit 1
fi

tar -xzf "$archive" -C "$tmpdir"

icon_source="$tmpdir/$archive_top_dir/resources/app/resources/linux/code.png"

rm -rf "${install_root}.new"

mkdir -p "${install_root}.new/$install_dir"

cp -a \
    "$tmpdir/$archive_top_dir/." \
    "${install_root}.new/$install_dir/"

printf '%s\n' "$version" \
    > "${install_root}.new/.linuxcapable-version"

if [ -f "${install_root}.new/$install_dir/chrome-sandbox" ]; then
    chown root:root \
        "${install_root}.new/$install_dir/chrome-sandbox"

    chmod 4755 \
        "${install_root}.new/$install_dir/chrome-sandbox"
fi

if [ -d "$install_root" ]; then
    rm -rf "${install_root}.previous"
    mv "$install_root" "${install_root}.previous"
fi

mv "${install_root}.new" "$install_root"

ln -sfn \
    "$install_root/$install_dir/antigravity-ide" \
    "$command_link"

mkdir -p "$(dirname "$icon_file")"

install -m 0644 "$icon_source" "$icon_file"

cat > "$desktop_file" <<DESKTOP
[Desktop Entry]
Name=Antigravity IDE
Comment=Google Antigravity IDE
Exec=$command_link %U
Icon=antigravity-ide
Terminal=false
Type=Application
Categories=Development;IDE;
MimeType=x-scheme-handler/antigravity-ide;application/x-antigravity-workspace;
StartupNotify=true
StartupWMClass=antigravity-ide
DESKTOP

update-desktop-database /usr/share/applications >/dev/null 2>&1 || true
gtk-update-icon-cache -q /usr/share/icons/hicolor 2>/dev/null || true

echo
echo "Installed Antigravity IDE $version"
echo "Location: $install_root/$install_dir"
echo
echo "Launcher command:"
echo "  antigravity-ide"
